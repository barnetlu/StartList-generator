@page "/"
@inject HttpClient Http
@inject IJSRuntime JS
@using ClosedXML.Excel
@using IO_Adapters
@using IO_Adapters.Mapping
@using IO_Adapters.Mapping.IO_Adapters.Mapping
@using IO_Adapters.Interfaces
@using IO_Adapters.Excel
@using IO_Adapters.SchedulerConfig
@using StartList_Core.Models
@using StartList_Core.Models.Enums
@using StartList_Core.Scheduling
@using StartList_Core.Scheduling.Config
@using StartList_Core.Scheduling.Report
@using Microsoft.AspNetCore.Components.Forms
@using System.Text

<style>
    .app-header {
        background: #0d6efd;
        color: #fff;
        text-align: center;
        padding: 10px 0;
        font-size: 1.2rem;
        font-weight: 600;
        letter-spacing: .03em;
        flex-shrink: 0;
    }
    .layout {
        display: flex;
        height: calc(100vh - 46px);
        gap: 0;
    }
    .panel-left {
        width: 350px;
        min-width: 290px;
        flex-shrink: 0;
        overflow-y: auto;
        padding: 14px 14px 14px 16px;
        border-right: 2px solid #dee2e6;
        background: #eef2f7;
    }
    .panel-right {
        flex: 1;
        overflow-y: auto;
        padding: 16px;
        background: #fff;
    }
    .section-label {
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: #495057;
        margin-top: 14px;
        margin-bottom: 6px;
        border-bottom: 1px solid #ced4da;
        padding-bottom: 3px;
    }
    .section-label:first-child {
        margin-top: 0;
    }
    .cat-item {
        padding: 5px 10px;
        margin: 2px 0;
        border: 1px solid #dee2e6;
        background: #fff;
        border-radius: 4px;
        cursor: grab;
        user-select: none;
        font-size: 0.875rem;
    }
    .cat-item.drag-over {
        border-color: #0d6efd;
        background: #e8f0fe;
    }
    .heat-cell {
        min-width: 140px;
        padding: 6px 8px;
        vertical-align: top;
    }
    .heat-cell.drag-over {
        background: #cfe2ff !important;
    }
    .lane-swatch {
        width: 22px;
        height: 22px;
        border: 1px solid #adb5bd;
        border-radius: 3px;
        display: inline-block;
        vertical-align: middle;
    }
    input[type=number].num-short {
        width: 65px;
    }
</style>

<div class="app-header">Generátor startovek</div>

<div class="layout">

    <!-- LEVÝ PANEL – ovládání -->
    <div class="panel-left">

        <div class="section-label">Disciplína</div>
        <select class="form-select form-select-sm mb-3" @bind="_discipline">
            <option value="100">100m překážky</option>
            <option value="60">60m překážky</option>
        </select>

        <div class="section-label">Přihlášky</div>
        <InputFile OnChange="SouborVybran" accept=".csv,.txt,.xlsx" multiple class="form-control form-control-sm mb-2" />
        @if (_pendingFiles.Count > 0)
        {
            <div class="d-flex align-items-center gap-2 mb-2">
                <span class="badge bg-secondary">@_pendingFiles.Count souborů</span>
                <button class="btn btn-sm btn-primary" @onclick="NactiSoubory">Načíst přihlášky</button>
            </div>
        }
        @if (_status != null)
        {
            <div class="alert alert-info py-1 px-2 mb-2" style="font-size:0.8rem">@_status</div>
        }

        @if (_competitors != null)
        {
            <div class="section-label">Konfigurace tratě</div>
            <div class="mb-3">
                <div class="d-flex align-items-center mb-2 gap-2">
                    <label class="col-form-label col-form-label-sm" style="width:200px">Počet drah:</label>
                    <input type="number" class="form-control form-control-sm num-short"
                           value="@_tp.TotalLanes" min="1" max="10"
                           @onchange="@(e => { _tp.TotalLanes = int.Parse(e.Value!.ToString()!); InitLaneColors(_tp.TotalLanes); })" />
                </div>
                @if (_discipline == "100")
                {
                    <div class="d-flex align-items-center mb-2 gap-2">
                        <label class="col-form-label col-form-label-sm" style="width:200px">170 cm před přepnutím:</label>
                        <input type="number" class="form-control form-control-sm num-short" @bind="_tp.InitialBariera170Lanes" min="0" max="@_tp.TotalLanes" />
                    </div>
                    <div class="d-flex align-items-center mb-2 gap-2">
                        <label class="col-form-label col-form-label-sm" style="width:200px">200 cm před přepnutím:</label>
                        <input type="number" class="form-control form-control-sm num-short" @bind="_tp.InitialBariera200Lanes" min="0" max="@_tp.TotalLanes" />
                    </div>
                    <div class="d-flex align-items-center mb-2 gap-2">
                        <label class="col-form-label col-form-label-sm" style="width:200px">170 cm po přepnutí:</label>
                        <input type="number" class="form-control form-control-sm num-short" @bind="_tp.AfterSwitchBariera170Lanes" min="0" max="@_tp.TotalLanes" />
                    </div>
                    <div class="d-flex align-items-center mb-2 gap-2">
                        <label class="col-form-label col-form-label-sm" style="width:200px">200 cm po přepnutí:</label>
                        <input type="number" class="form-control form-control-sm num-short" @bind="_tp.AfterSwitchBariera200Lanes" min="0" max="@_tp.TotalLanes" />
                    </div>
                }
                else
                {
                    <div class="d-flex align-items-center mb-2 gap-2">
                        <label class="col-form-label col-form-label-sm" style="width:200px">Bariér před přepnutím:</label>
                        <input type="number" class="form-control form-control-sm num-short" @bind="_tp.InitialBarieraLanes" min="0" max="@_tp.TotalLanes" />
                    </div>
                    <div class="d-flex align-items-center mb-2 gap-2">
                        <label class="col-form-label col-form-label-sm" style="width:200px">Bariér po přepnutí:</label>
                        <input type="number" class="form-control form-control-sm num-short" @bind="_tp.AfterSwitchBarieraLanes" min="0" max="@_tp.TotalLanes" />
                    </div>
                }
                <div class="d-flex align-items-center mb-2 gap-2">
                    <label class="col-form-label col-form-label-sm" style="width:200px">Přepínání překážek:</label>
                    <select class="form-select form-select-sm num-short" style="width:auto" @bind="_tp.SwitchRule">
                        <option value="@SwitchRuleType.Automatic">Auto</option>
                        <option value="@SwitchRuleType.Manual">Manuální</option>
                    </select>
                </div>
                <div class="d-flex align-items-center mb-2 gap-2">
                    <label class="col-form-label col-form-label-sm" style="width:200px">Max. 1 klub na rozběh:</label>
                    <div class="form-check mb-0">
                        <input class="form-check-input" type="checkbox" @bind="_maxOneClubPerHeat" />
                    </div>
                </div>
                <div class="d-flex align-items-center mb-2 gap-2">
                    <label class="col-form-label col-form-label-sm" style="width:200px">Cooldown kol mezi kluby:</label>
                    <input type="number" class="form-control form-control-sm num-short" @bind="_clubCooldownHeats" min="1" max="10" />
                </div>
            </div>

            @if (_categoryOrder.Count > 0)
            {
                <div class="section-label">Pořadí kategorií <span class="fw-normal text-muted" style="font-size:0.75rem">(přetažením)</span></div>
                <div class="mb-3">
                    @for (int ci = 0; ci < _categoryOrder.Count; ci++)
                    {
                        var ciCopy = ci;
                        var key = _categoryOrder[ci];
                        var isDragOver = _catDragOver == ciCopy;
                        <div class="cat-item @(isDragOver ? "drag-over" : "")"
                             draggable="true"
                             @ondragstart="@(() => OnCatDragStart(ciCopy))"
                             @ondragover:preventDefault="true"
                             @ondragover="@(() => OnCatDragOver(ciCopy))"
                             @ondragleave="OnCatDragLeave"
                             @ondrop="@(() => OnCatDrop(ciCopy))">
                            <span class="text-muted me-1">@(ciCopy + 1).</span> @CategoryKeyLabel(key)
                        </div>
                    }
                </div>
            }

            <div class="section-label">Číslování startovních čísel</div>
            <div class="mb-2">
                <div class="form-check">
                    <input class="form-check-input" type="radio" name="snmode" id="sn-global"
                           checked="@(_startNumberMode == StartNumberMode.GlobalSequential)"
                           @onchange="@(() => _startNumberMode = StartNumberMode.GlobalSequential)" />
                    <label class="form-check-label" for="sn-global" style="font-size:0.85rem">Kontinuální</label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="radio" name="snmode" id="sn-heat"
                           checked="@(_startNumberMode == StartNumberMode.PerHeat)"
                           @onchange="@(() => _startNumberMode = StartNumberMode.PerHeat)" />
                    <label class="form-check-label" for="sn-heat" style="font-size:0.85rem">Podle rozběhu (barva = rozběh)</label>
                </div>
            </div>

            @if (_startNumberMode == StartNumberMode.PerHeat && _laneColors.Count > 0)
            {
                <div class="mb-3">
                    @foreach (var lc in _laneColors)
                    {
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <label class="col-form-label col-form-label-sm" style="width:65px;font-size:0.8rem">Dráha @lc.Lane:</label>
                            <select class="form-select form-select-sm" style="width:110px"
                                    value="@lc.Color.Name"
                                    @onchange="@(e => lc.Color = _colorOptions.First(o => o.Name == e.Value!.ToString()))">
                                @foreach (var opt in _colorOptions)
                                {
                                    <option value="@opt.Name" selected="@(opt.Name == lc.Color.Name)">@opt.Name</option>
                                }
                            </select>
                            <span class="lane-swatch" style="background:@lc.Color.CssColor"></span>
                        </div>
                    }
                </div>
            }

            <div class="d-grid gap-2 mt-2">
                <button class="btn btn-primary" @onclick="GenerujStartovku">Generovat startovku</button>
                @if (_heats != null)
                {
                    <button class="btn btn-success" @onclick="ExportujExcel">Exportovat do Excelu</button>
                }
            </div>
            @if (_generateStatus != null)
            {
                <div class="alert alert-secondary py-1 px-2 mt-2" style="font-size:0.8rem">@_generateStatus</div>
            }
        }

    </div>

    <!-- PRAVÝ PANEL – konflikty + načtení závodníci -->
    <div class="panel-right">
        @if (_conflicts.Count > 0 && !_conflictsConfirmed)
        {
            <div class="d-flex align-items-center mb-2 gap-2">
                <h5 class="mb-0">Konflikty k potvrzení</h5>
                <span class="badge bg-warning text-dark">@_conflicts.Count</span>
            </div>
            <div class="table-responsive mb-2">
                <table class="table table-sm table-bordered table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Soubor</th>
                            <th>Řádek</th>
                            <th>Závodník</th>
                            <th>Popis konfliktu</th>
                            <th>Potvrzená hodnota</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in _conflicts)
                        {
                            <tr>
                                <td><small>@c.FileName</small></td>
                                <td>@c.RowNumber</td>
                                <td>@c.FirstName @c.LastName</td>
                                <td><small>@c.Description</small></td>
                                <td>
                                    @if (c.Type == ConflictType.BirthYearUnknown)
                                    {
                                        <input type="number" class="form-control form-control-sm num-short" @bind="c.ConfirmedBirthYear" min="1950" max="@DateTime.Now.Year" />
                                    }
                                    else if (c.Type == ConflictType.SexUnknown)
                                    {
                                        <select class="form-select form-select-sm" style="width:auto" @bind="c.ConfirmedSex">
                                            <option value="@SexEnum.Male">Muž</option>
                                            <option value="@SexEnum.Female">Žena</option>
                                        </select>
                                    }
                                    else if (c.Type == ConflictType.AgeGroupMismatch)
                                    {
                                        <select class="form-select form-select-sm" style="width:auto" @bind="c.ConfirmedAgeGroup">
                                            @foreach (var ag in Enum.GetValues<AgeGroup>().Where(a => a != AgeGroup.Unknown))
                                            {
                                                <option value="@ag">@ag</option>
                                            }
                                        </select>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <button class="btn btn-sm btn-primary mb-3" @onclick="PotvrditANacistZnovu">Potvrdit a načíst znovu</button>
        }

        @if (_duplicates.Count > 0)
        {
            <div class="d-flex align-items-center mb-2 gap-2">
                <h5 class="mb-0">Možné duplicity</h5>
                <span class="badge bg-danger">@_duplicates.Count</span>
            </div>
            <div class="table-responsive mb-2">
                <table class="table table-sm table-bordered table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Závodník</th>
                            <th>Klub</th>
                            <th>Ročník</th>
                            <th>Soubory</th>
                            <th>Akce</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var dup in _duplicates)
                        {
                            <tr>
                                <td>
                                    @{ var first = dup.Entries[0].Entry.Competitor; }
                                    @first.FirstName @first.LastName
                                </td>
                                <td>@first.Club</td>
                                <td>@first.BirthYear</td>
                                <td>
                                    @foreach (var (_, entry) in dup.Entries)
                                    {
                                        <div><small class="text-muted">@entry.SourceFile</small></div>
                                    }
                                </td>
                                <td>
                                    <select class="form-select form-select-sm" @bind="dup.KeepIndex">
                                        <option value="">Zachovat oba</option>
                                        @foreach (var (idx, entry) in dup.Entries)
                                        {
                                            <option value="@idx">Zachovat z: @entry.SourceFile</option>
                                        }
                                    </select>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <button class="btn btn-sm btn-primary mb-3" @onclick="PotvrditDuplicity">Potvrdit a pokračovat</button>
        }

        @if (_heats != null)
        {
            <div class="d-flex align-items-center mb-2 gap-2">
                <h5 class="mb-0">Startovka</h5>
                <span class="badge bg-primary">@_heats.Count rozběhů</span>
                <small class="text-muted">přetažením prohoďte závodníky</small>
            </div>
            <div class="table-responsive">
                <table class="table table-sm table-bordered align-middle" style="border-collapse:collapse">
                    <thead class="table-light">
                        <tr>
                            <th class="text-center" style="width:60px">Rozběh</th>
                            @for (int l = 1; l <= _tp.TotalLanes; l++)
                            {
                                <th class="text-center">Dráha @l</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @for (int hi = 0; hi < _heats.Count; hi++)
                        {
                            var heat = _heats[hi];
                            var hiCopy = hi;
                            <tr>
                                <td class="text-center fw-bold">@heat.Number</td>
                                @for (int li = 0; li < _tp.TotalLanes; li++)
                                {
                                    var liCopy = li;
                                    var comp = heat.Lanes.Length > li ? heat.Lanes[li] : null;
                                    var isDragOver = _dragOverHeat == hiCopy && _dragOverLane == liCopy;
                                    <td class="heat-cell @(isDragOver ? "drag-over" : "")"
                                        draggable="@(comp != null ? "true" : "false")"
                                        @ondragstart="@(() => OnDragStart(hiCopy, liCopy))"
                                        @ondragover:preventDefault="true"
                                        @ondragover="@(() => OnDragOver(hiCopy, liCopy))"
                                        @ondragleave="@(() => OnDragLeave())"
                                        @ondrop="@(() => OnDrop(hiCopy, liCopy))">
                                        @if (comp != null)
                                        {
                                            <div style="cursor:grab;user-select:none">
                                                <strong>@comp.FirstName @comp.LastName</strong><br />
                                                <small class="text-muted">@comp.Club</small><br />
                                                <small class="text-muted">@comp.Category.Name</small>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else if (_competitors != null)
        {
            <div class="d-flex align-items-center mb-2 gap-2">
                <h5 class="mb-0">Načtení závodníci</h5>
                <span class="badge bg-secondary">@_competitors.Count z @_loadedFileCount souborů</span>
            </div>
            <div class="table-responsive">
                <table class="table table-sm table-bordered table-striped table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Jméno</th>
                            <th>Příjmení</th>
                            <th>Klub</th>
                            <th>Ročník</th>
                            <th>Kategorie</th>
                            <th>Soubor</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < _competitors.Count; i++)
                        {
                            var entry = _competitors[i];
                            <tr>
                                <td>@(i + 1)</td>
                                <td>@entry.Competitor.FirstName</td>
                                <td>@entry.Competitor.LastName</td>
                                <td>@entry.Competitor.Club</td>
                                <td>@entry.Competitor.BirthYear</td>
                                <td>@entry.Competitor.Category.Name</td>
                                <td><small class="text-muted">@entry.SourceFile</small></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <h6 class="mt-3">Počty závodníků za týmy</h6>
            <div class="table-responsive">
                <table class="table table-sm table-bordered table-hover" style="max-width:400px">
                    <thead class="table-light">
                        <tr>
                            <th>Tým</th>
                            <th class="text-center">Počet</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var g in _competitors.GroupBy(e => e.Competitor.Club).OrderBy(g => g.Key))
                        {
                            <tr>
                                <td>@g.Key</td>
                                <td class="text-center">@g.Count()</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        @if (_competitors != null && _colorOptions.Count > 0)
        {
            <div class="mt-4 border-top pt-3">
                <h6>Číslování závodníků</h6>
                <div class="mb-2" style="font-size:0.82rem;color:#6c757d">
                    Přiřaď barvu čísla každé kategorii. Závodníci sdílející barvu dostanou čísla ze společné řady (po sborech za sebou).
                </div>
                <div class="table-responsive mb-2">
                    <table class="table table-sm table-bordered" style="max-width:420px">
                        <thead class="table-light">
                            <tr><th>Kategorie</th><th>Barva čísla</th><th class="text-center">Počet</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var cat in _competitors.Select(c => c.Competitor.Category).DistinctBy(c => c.Code).OrderBy(c => c.Name))
                            {
                                var catCode = cat.Code;
                                var catCount = _competitors.Count(c => c.Competitor.Category.Code == catCode);
                                <tr>
                                    <td>@cat.Name</td>
                                    <td>
                                        <div class="d-flex align-items-center gap-1">
                                            <select class="form-select form-select-sm" style="width:110px"
                                                    value="@(_cislovaniColors.TryGetValue(catCode, out var cn) ? cn : _colorOptions[0].Name)"
                                                    @onchange="@(e => _cislovaniColors[catCode] = e.Value!.ToString()!)">
                                                @foreach (var opt in _colorOptions)
                                                {
                                                    <option value="@opt.Name">@opt.Name</option>
                                                }
                                            </select>
                                            <span class="lane-swatch" style="background:@(_colorOptions.FirstOrDefault(o => o.Name == (_cislovaniColors.TryGetValue(catCode, out var n) ? n : _colorOptions[0].Name))?.CssColor)"></span>
                                        </div>
                                    </td>
                                    <td class="text-center">@catCount</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <button class="btn btn-sm btn-outline-primary mb-2" @onclick="ExportujCisla">Exportovat čísla do Excelu</button>
                @if (_cislovaniStatus != null)
                {
                    <div class="alert alert-secondary py-1 px-2 mt-2" style="font-size:0.8rem">@_cislovaniStatus</div>
                }
            </div>
        }

        @if (_competitors != null)
        {
            <div class="mt-4 border-top pt-3">
                <h6>Porovnání s ligou</h6>
                <div class="mb-2" style="font-size:0.82rem;color:#6c757d">
                    Nahraj ligové soubory (.xlsx/.xlsm) pro kontrolu, kdo v lize chybí.
                </div>
                <div class="mb-2">
                    <label class="form-label form-label-sm mb-1">Děti (Přípravka, Mladší, Starší)</label>
                    <InputFile OnChange="@(e => LigaSouborVybran(e, LigaTyp.Deti))" accept=".xlsx,.xlsm" class="form-control form-control-sm" />
                    @if (_ligaDetiName != null) { <small class="text-success">@_ligaDetiName</small> }
                </div>
                <div class="mb-2">
                    <label class="form-label form-label-sm mb-1">Dorost</label>
                    <InputFile OnChange="@(e => LigaSouborVybran(e, LigaTyp.Dorost))" accept=".xlsx,.xlsm" class="form-control form-control-sm" />
                    @if (_ligaDorostName != null) { <small class="text-success">@_ligaDorostName</small> }
                </div>
                <div class="mb-2">
                    <label class="form-label form-label-sm mb-1">Dospělí (Muži, Ženy)</label>
                    <InputFile OnChange="@(e => LigaSouborVybran(e, LigaTyp.Dospeli))" accept=".xlsx,.xlsm" class="form-control form-control-sm" />
                    @if (_ligaDospeliName != null) { <small class="text-success">@_ligaDospeliName</small> }
                </div>
                <button class="btn btn-sm btn-outline-primary mb-2"
                        @onclick="PorovnejSLigou"
                        disabled="@(_ligaDetiBytes == null && _ligaDorostBytes == null && _ligaDospeliBytes == null)">
                    Porovnat s ligou
                </button>
                @if (_ligaStatus != null)
                {
                    <div class="alert alert-secondary py-1 px-2 mb-2" style="font-size:0.8rem">@_ligaStatus</div>
                }
                @if (_ligaVysledky != null)
                {
                    var chybi    = _ligaVysledky.Where(v => v.Stav == LigaStav.Chybi).ToList();
                    var obracene = _ligaVysledky.Where(v => v.Stav == LigaStav.Obracene).ToList();
                    <div class="d-flex gap-2 mb-3 flex-wrap">
                        <span class="badge bg-success">OK: @_ligaVysledky.Count(v => v.Stav == LigaStav.Ok)</span>
                        <span class="badge bg-danger">Chybí: @chybi.Count</span>
